{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: nodeunit test-render-retry.js",
      "runtimeExecutable": "node",
      "program": "${workspaceFolder}/node_modules/nodeunit/bin/nodeunit",
      "args": ["test/test-render-retry.js"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: nodeunit (all tests)",
      "runtimeExecutable": "node",
      "program": "${workspaceFolder}/node_modules/nodeunit/bin/nodeunit",
      "args": ["test"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
